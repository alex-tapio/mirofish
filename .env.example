# =============================================================
# MiroFish Configuration
# =============================================================
# Copy this file to .env and fill in your values.
# Users provide their own LLM API keys via the Settings page.
# =============================================================

# ===== LLM Configuration (OpenAI-compatible format) =====
# Default provider used when no user key is provided.
# Supports OpenAI, Anthropic (via proxy), or any OpenAI-compatible API.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-5-mini

# ===== Neo4j Aura Configuration =====
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-password

# ===== Embedding Configuration =====
# Uses OpenAI embeddings by default. Set to any OpenAI-compatible endpoint.
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=

# ===== OASIS / CAMEL-AI Configuration =====
# CAMEL-AI reads these for its internal OpenAI client
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1

# ===== Flask =====
SECRET_KEY=change-me-in-production
FLASK_DEBUG=False
